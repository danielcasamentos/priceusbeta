# Configurações do Supabase Local (Docker)
# Copie este arquivo e salve como '.env.development.local' na raiz do projeto.
# Em seguida, substitua o VITE_SUPABASE_ANON_KEY pela chave gerada ao rodar 'npx supabase start'.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=INSIRA_SUA_ANON_KEY_LOCAL_AQUI

# Tempo limite da sessão em milissegundos
VITE_SESSION_TIMEOUT=1800000

# ID do Usuário de Teste Local (caso queira ignorar Stripe no desenvolvimento local)
VITE_DEV_USER_ID=example-user-id
